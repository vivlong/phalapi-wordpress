{
    "name": "vivlong/phalapi-wordpress",
    "description": "PhalApi 2.x 扩展类库，用于操作 WordPress。",
    "type": "library",
    "keywords": [
        "phalapi",
        "phalapi-wordpress",
        "wordpress",
        "rest-api",
        "api-client"
    ],
    "license": "MulanPSL-2.0",
    "homepage": "https://www.phalapi.net/",
    "authors": [
        {
            "name": "vivlong",
            "email": "vivlonglz@gmail.com",
            "homepage": "https://vivlong.github.io",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.0.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PhalApi\\Wordpress\\": "src"
        }
    },
    "scripts": {
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse src",
        "sniff": "phpcs src",
        "sniff:fix": "phpcbf src"
    },
    "scripts-descriptions": {
        "cs:check": "Check coding style with PHP-CS-Fixer",
        "cs:fix": "Fix coding style with PHP-CS-Fixer",
        "phpstan": "Run static analysis with PHPStan",
        "sniff": "Check coding style with PHPCS",
        "sniff:fix": "Fix coding style with PHPCS"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "suggest": {
        "ext-json": "Required to use JSON responses",
        "ext-curl": "Required for cURL HTTP client"
    }
}
